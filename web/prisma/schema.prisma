// ==============================================================================
// HiveNode — Prisma Schema
// ==============================================================================
// Fonte da verdade: HiveNode.md (Seção 4)
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// Models
// ==============================================================================

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  role             Role           @default(CUSTOMER)
  balanceGB        Float          @default(0.0)
  
  // Integração Web3 & Tokenomics
  walletAddress    String?
  hivePoints       Float          @default(0.0)
  referralCode     String         @unique @default(uuid())
  referredById     String?
  
  // Segurança / 2FA
  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)

  abacatePayCustId String?
  nodes            Node[]
  proxies          ProxyCredential[]
  subscriptions    Subscription[]
  pointsLedger     PointsLedger[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("users")
}

model Node {
  id           String     @id @default(uuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         NodeType
  status       NodeStatus @default(OFFLINE)
  visibility   NodeVisibility @default(PRIVATE)
  deviceModel  String?
  ipAddress    String?
  tags         String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  proxies      ProxyCredential[]
  shares       NodeShare[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([visibility])
  @@map("nodes")
}

model ProxyCredential {
  id           String     @id @default(uuid())
  nodeId       String
  node         Node       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proxyUser    String     @unique
  proxyPass    String
  totalBytesRx BigInt     @default(0)
  totalBytesTx BigInt     @default(0)
  status       NodeStatus @default(ONLINE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([nodeId])
  @@index([userId])
  @@map("proxy_credentials")
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType         PlanType
  status           SubStatus @default(ACTIVE)
  abacatePaySubId  String?
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model PointsLedger {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  type         PointType
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([type])
  @@map("points_ledger")
}

model NodeShare {
  id              String      @id @default(uuid())
  nodeId          String
  node            Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  ownerId         String
  sharedWithEmail String
  sharedWithId    String?     
  maxProxies      Int         @default(1)
  quotaBytesTx    BigInt      @default(0)
  status          ShareStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([ownerId])
  @@index([nodeId])
  @@map("node_shares")
}

// ==============================================================================
// Enums
// ==============================================================================

enum Role {
  CUSTOMER
  ADMIN
}

enum NodeType {
  BYOD
  MASTER_MOBILE
  DATACENTER
}

enum NodeStatus {
  ONLINE
  OFFLINE
  BLOCKED
}

enum PlanType {
  BYOD_MONTHLY
  PREMIUM_METERED
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum NodeVisibility {
  PRIVATE
  PUBLIC
}

enum PointType {
  UPTIME
  TRAFFIC
  REFERRAL
  CLAIM
}

enum ShareStatus {
  PENDING
  ACCEPTED
  REVOKED
}
