// ==============================================================================
// HiveNode — Prisma Schema
// ==============================================================================
// Fonte da verdade: HiveNode.md (Seção 4)
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// Models
// ==============================================================================

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  role             Role           @default(CUSTOMER)
  balanceGB        Float          @default(0.0)
  
  // Integração Web3 & Tokenomics
  walletAddress    String?
  hivePoints       Float          @default(0.0)
  referralCode     String         @unique @default(uuid())
  referredById     String?
  
  // Segurança / 2FA
  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)

  abacatePayCustId String?
  activePlanId     String?
  nodes            Node[]
  proxies          ProxyCredential[]
  subscriptions    Subscription[]
  payments         Payment[]
  pointsLedger     PointsLedger[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("users")
}

model Node {
  id           String     @id @default(uuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         NodeType
  status       NodeStatus @default(OFFLINE)
  visibility   NodeVisibility @default(PRIVATE)
  deviceModel  String?
  ipAddress    String?
  tags         String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  proxies      ProxyCredential[]
  shares       NodeShare[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([visibility])
  @@map("nodes")
}

model ProxyCredential {
  id           String     @id @default(uuid())
  nodeId       String
  node         Node       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proxyUser    String     @unique
  proxyPass    String
  totalBytesRx BigInt     @default(0)
  totalBytesTx BigInt     @default(0)
  status       NodeStatus @default(ONLINE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([nodeId])
  @@index([userId])
  @@map("proxy_credentials")
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String?
  planType         PlanType
  status           SubStatus @default(ACTIVE)
  abacatePaySubId  String?
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Plan {
  id               String       @id @default(uuid())
  slug             String       @unique
  name             String
  category         PlanCategory
  priceInCents     Int          @default(0)
  maxDevices       Int          @default(0)
  maxProxies       Int          @default(0)
  gbIncluded       Float        @default(0)
  gbPriceCents     Int          @default(0)
  isRecurring      Boolean      @default(false)
  billingCycle     String?
  isPublic         Boolean      @default(true)
  isAdminOnly      Boolean      @default(false)
  extraDeviceCents Int          @default(0)
  extraProxyCents  Int          @default(0)
  minMonthsForPPU  Int          @default(0)
  minAvgGbForPPU   Float        @default(0)
  abacateProductId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("plans")
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId            String?
  type              PaymentType
  amountCents       Int
  status            PaymentStatus @default(PENDING)
  abacateCheckoutId String?
  abacateSubId      String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model PointsLedger {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  type         PointType
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([type])
  @@map("points_ledger")
}

model NodeShare {
  id              String      @id @default(uuid())
  nodeId          String
  node            Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  ownerId         String
  sharedWithEmail String
  sharedWithId    String?     
  maxProxies      Int         @default(1)
  quotaBytesTx    BigInt      @default(0)
  status          ShareStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([ownerId])
  @@index([nodeId])
  @@map("node_shares")
}

// ==============================================================================
// Enums
// ==============================================================================

enum Role {
  CUSTOMER
  ADMIN
}

enum NodeType {
  BYOD
  MASTER_MOBILE
  DATACENTER
}

enum NodeStatus {
  ONLINE
  OFFLINE
  BLOCKED
}

enum PlanType {
  FOUNDER
  STARTER
  PRO
  ENTERPRISE
  GB_BASIC
  GB_INTERMEDIATE
  GB_ADVANCED
  PAY_AS_YOU_GO
  FREE
  BYOD_MONTHLY
  PREMIUM_METERED
}

enum PlanCategory {
  GENERAL
  PRIVATE_FLEET
  GLOBAL_FLEET
  PAY_PER_USE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PENDING
}

enum PaymentType {
  SUBSCRIPTION
  ONE_TIME
  PAY_PER_USE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NodeVisibility {
  PRIVATE
  PUBLIC
}

enum PointType {
  UPTIME
  TRAFFIC
  REFERRAL
  CLAIM
}

enum ShareStatus {
  PENDING
  ACCEPTED
  REVOKED
}
