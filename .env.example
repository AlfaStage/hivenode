# ==============================================================================
# HiveNode - Variáveis de Ambiente Global (Docker Compose)
# Domínio Principal (VPS): hivenode.alfastage.com.br
# Wildcard: *.hivenode.alfastage.com.br
# ==============================================================================

COMPOSE_PROJECT_NAME=hivenode

# ------------------------------------------------------------------------------
# Banco de Dados Local (PostgreSQL - Docker)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@localhost:5432/hivenode?schema=public"

# ------------------------------------------------------------------------------
# Cache / Filas / Comunicação Local (Redis - Docker)
# ------------------------------------------------------------------------------
REDIS_URL="redis://:pass@localhost:6379/0"

# ------------------------------------------------------------------------------
# Autenticação e Segurança (JWT)
# ------------------------------------------------------------------------------
JWT_SECRET="SEU_JWT_SECRET_AQUI"
ENCRYPTION_KEY="SUA_CHAVE_DE_ENCRIPTACAO_32_BYTES"

# ------------------------------------------------------------------------------
# Gateway de Pagamento (Abacate Pay API v2)
# ------------------------------------------------------------------------------
ABACATE_PAY_API_KEY="SUA_API_KEY_ABACATE_PAY"
ABACATE_PAY_WEBHOOK_SECRET="SEU_WEBHOOK_SECRET_ABACATE_PAY"
ABACATe_PAY_MODE="dev"
ABACATE_PAY_API_VERÇÂO="v2"
ABACATE_PAY_WEBHOOK_ROTA_URL="/webhook/abacatepay"
ABACATE_PAY_DOCUMENTAÇÃO="https://www.abacatepay.com/llms.txt"

# ------------------------------------------------------------------------------
# Configurações do Frontend (Next.js)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
WEB_PORT=3000

# ------------------------------------------------------------------------------
# Configurações do Broker (Go)
# ------------------------------------------------------------------------------
BROKER_SOCKS5_PORT=10000
BROKER_TUNNEL_PORT=10001
BROKER_BILLING_FLUSH_MB=5
BROKER_BILLING_FLUSH_SEC=30
